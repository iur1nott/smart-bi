# SmartXL - Streamlit Secrets Configuration Template
# ===================================================
# Copy this file to secrets.toml and fill in your actual values.
#
# Usage:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   # Edit secrets.toml with your actual credentials
#
# For Streamlit Community Cloud:
#   Go to your app settings > Secrets and paste the contents
#
# IMPORTANT: Never commit secrets.toml to version control!

# Database Configuration
# ----------------------
# Get your Supabase database URL from: Project Settings > Database > Connection string

[database]
# Direct Connection URL
# url = "postgresql://postgres:sup4Gr3sF0rTcc@db.evhkyacjxcughuslwqyw.supabase.co:5432/postgres"
# TRANSACTION POOLER URL
url = "postgresql://postgres.evhkyacjxcughuslwqyw:sup4Gr3sF0rTcc@aws-1-sa-east-1.pooler.supabase.com:6543/postgres"
pool_size = 5
max_overflow = 10
pool_recycle = 3600
echo_sql = false

# S3 Storage Configuration
# ------------------------
# For Supabase Storage:
#   1. Go to Project Settings > Storage
#   2. Enable S3-compatible storage
#   3. Generate Access Keys
[storage]
endpoint_url = "https://YOUR_PROJECT.supabase.co/storage/v1/s3"
access_key = "YOUR_ACCESS_KEY_ID"
secret_key = "YOUR_SECRET_ACCESS_KEY"
bucket_name = "smartxl-files"
region = "us-east-1"
use_ssl = true
presigned_url_expiration = 3600

# JWT Authentication
# ------------------
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
[jwt]
secret_key = "your-secure-random-string-change-this-in-production"
algorithm = "HS256"
access_token_expire_minutes = 60
refresh_token_expire_days = 7

[session]
timeout_hours = 24
cleanup_interval_hours = 1

[app]
name = "SmartXL"
version = "2.0.0"
debug = false

[security]
password_min_length = 8
max_login_attempts = 5
login_lockout_minutes = 15
