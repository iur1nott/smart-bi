# Dashboard Builder - Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_USER=dashboard_user
POSTGRES_PASSWORD=dashboard_password
POSTGRES_DB=dashboard_builder
POSTGRES_PORT=5432

# Full database URL (constructed automatically in docker-compose)
DATABASE_URL=postgresql://dashboard_user:dashboard_password@postgres:5432/dashboard_builder

# For local development (outside Docker)
DATABASE_URL_LOCAL=postgresql://dashboard_user:dashboard_password@localhost:5432/dashboard_builder

# =============================================================================
# JWT Configuration
# =============================================================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Streamlit Configuration
# =============================================================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
STREAMLIT_SERVER_RUN_ON_SAVE=true
STREAMLIT_SERVER_FILE_WATCHER_TYPE=poll

# =============================================================================
# Docker Ports (override defaults)
# =============================================================================
APP_PORT=8501
PGADMIN_PORT=5050

# =============================================================================
# pgAdmin Configuration (development only)
# =============================================================================
PGADMIN_EMAIL=admin@localhost.com
PGADMIN_PASSWORD=admin

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_REGISTRATION=true
ENABLE_EXPORT=true
MAX_FILE_SIZE_MB=50

# =============================================================================
# UV Package Manager Settings
# =============================================================================
UV_COMPILE_BYTECODE=1
UV_LINK_MODE=copy
UV_PYTHON_PREFERENCE=only-managed

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
