# Dashboard Builder - Environment Configuration
# Copy this file to .env and modify the values as needed

# ===========================================
# DATABASE SETTINGS
# ===========================================
# PostgreSQL connection string
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dashboard_builder
DATABASE_URL="postgresql://postgres:Pst|Grs@localhost:5432/postgres"

# Database connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Enable SQL query logging (for debugging)
SQL_ECHO=false

# ===========================================
# JWT AUTHENTICATION SETTINGS
# ===========================================
# Secret key for signing JWT tokens - CHANGE THIS IN PRODUCTION!
JWT_SECRET_KEY=my-key

# Token expiration times
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# SESSION SETTINGS
# ===========================================
# User session timeout in hours
SESSION_TIMEOUT_HOURS=24

# How often to clean up expired sessions (hours)
SESSION_CLEANUP_INTERVAL_HOURS=1

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME=Dashboard Builder
APP_VERSION=1.0.0
DEBUG_MODE=false
APP_PORT=8501
APP_HOST=0.0.0.0

# ===========================================
# DATA PROCESSING SETTINGS
# ===========================================
# Maximum upload file size in MB
MAX_FILE_SIZE_MB=50

# Maximum rows to show in preview
MAX_ROWS_PREVIEW=100

# Number of sample values per column
SAMPLE_VALUES_COUNT=10

# Maximum unique values in filter dropdowns
MAX_UNIQUE_VALUES_DISPLAY=100

# Thresholds for column type detection (0.0 - 1.0)
DATETIME_DETECTION_THRESHOLD=0.7
CATEGORICAL_THRESHOLD=0.5
TEXT_THRESHOLD=0.8

# ===========================================
# EXPORT SETTINGS
# ===========================================
# Directory for exported files
EXPORT_OUTPUT_DIR=./exports

# Default export options
EXPORT_PAPER_SIZE=a4
EXPORT_ORIENTATION=portrait
EXPORT_INCLUDE_COMMENTS=true

# ===========================================
# LOGGING SETTINGS
# ===========================================
LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# LOG_FILE=./logs/app.log

# ===========================================
# CHART SETTINGS
# ===========================================
CHART_DEFAULT_COLOR_SCHEME=default
CHART_DEFAULT_WIDTH=400
CHART_DEFAULT_HEIGHT=300

# ===========================================
# SECURITY SETTINGS
# ===========================================
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
